---
import GridCell from '../ui/GridCell.astro';
import CopyButton from '../interactive/CopyButton';

const installCommand = 'npm i @cloudflare/sandbox';
const docsUrl = 'https://developers.cloudflare.com/sandbox';
---

<div class="lg:grid lg:grid-cols-8 lg:border-l lg:auto-rows-fr flex flex-col lg:block">
  <!-- Desktop: 8 filler squares -->
  {Array.from({ length: 8 }).map(() => (
    <div class="hidden lg:block border-r border-b aspect-square"></div>
  ))}

  <!-- Mobile CTA buttons -->
  <div class="lg:hidden border p-6 space-y-4">
    <a
      href={docsUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="block text-center text-2xl sm:text-3xl md:text-4xl font-medium border rounded-full py-4 sm:py-6 hover:bg-foreground hover:text-background transition-colors"
    >
      Get Started ↗
    </a>
    <CopyButton
      client:load
      text={installCommand}
      label={installCommand}
      variant="pill"
      ariaLabel="Copy install command"
    />
  </div>

  <!-- Desktop: "Get Started" CTA — (2,1) 4×1 -->
  <GridCell x={2} y={1} width={4} height={1}>
    <a
      href={docsUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="text-6xl flex items-center justify-center h-[calc(100%+2px)] border rounded-full -my-px hover:bg-foreground hover:text-background transition-colors"
    >
      Get Started ↗
    </a>
  </GridCell>

  <!-- Desktop: npm install CTA — (4,2) 4×1 -->
  <GridCell x={4} y={2} width={4} height={1}>
    <CopyButton
      client:load
      text={installCommand}
      label={installCommand}
      variant="pill"
      ariaLabel="Copy npm install command"
    />
  </GridCell>
</div>
