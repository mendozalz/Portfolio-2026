---
import TextShadow from '../interactive/TextShadow';
---

<h1
  class="title mx-auto w-fit font-medium relative z-30 text-[70px] sm:text-[120px] md:text-[160px] lg:text-[260px] leading-none"
>
  <TextShadow client:load text="Lenin" count={3} />
  <TextShadow client:load text="Mendoza" count={3} />
</h1>

<!-- Sticky masking strip — slides over the title on scroll -->
<div class="h-6 bg-background sticky top-0 z-20 -mt-6 sm:-mt-10 lg:-mt-14"></div>
