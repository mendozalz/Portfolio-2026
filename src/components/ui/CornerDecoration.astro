---
// Renders 4 diagonal SVG corner decorations on a relative container
// No props needed — purely decorative
---

<!-- Top-left -->
<div
  class="absolute size-[17px] top-0 left-0 hidden lg:block [stroke:hsl(0,0%,0%)] dark:[stroke:hsl(0,0%,30%)]"
>
  <svg width="100%" height="100%" aria-hidden="true">
    <line x2="17" y2="17" stroke="currentColor"></line>
  </svg>
</div>

<!-- Top-right -->
<div
  class="absolute size-[17px] top-0 right-0 hidden lg:block [stroke:hsl(0,0%,0%)] dark:[stroke:hsl(0,0%,30%)]"
>
  <svg width="100%" height="100%" aria-hidden="true">
    <line y1="17" x2="17" stroke="currentColor"></line>
  </svg>
</div>

<!-- Bottom-left -->
<div
  class="absolute size-[17px] bottom-0 left-0 hidden lg:block [stroke:hsl(0,0%,0%)] dark:[stroke:hsl(0,0%,30%)]"
>
  <svg width="100%" height="100%" aria-hidden="true">
    <line y1="17" x2="17" stroke="currentColor"></line>
  </svg>
</div>

<!-- Bottom-right -->
<div
  class="absolute size-[17px] bottom-0 right-0 hidden lg:block [stroke:hsl(0,0%,0%)] dark:[stroke:hsl(0,0%,30%)]"
>
  <svg width="100%" height="100%" aria-hidden="true">
    <line x2="17" y2="17" stroke="currentColor"></line>
  </svg>
</div>
