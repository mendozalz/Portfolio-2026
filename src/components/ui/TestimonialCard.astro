---
import IconQuote from '../icons/IconQuote.astro';

interface Props {
  quote: string;
  name: string;
  role: string;
  company: string;
  companyUrl?: string;
  size?: 'sm' | 'lg';
}

const { quote, name, role, company, companyUrl, size = 'lg' } = Astro.props;

const textClass = size === 'lg' ? 'text-xl' : 'text-base';
const paddingClass = size === 'lg' ? 'p-6 gap-6' : 'p-4 gap-4';
---

<div
  class:list={[
    'relative bg-background w-full border border-b-0 flex flex-col flex-1',
    paddingClass,
  ]}
>
  <div class="flex flex-col flex-1">
    <div class="mb-2 flex items-center justify-between">
      <IconQuote width={24} class="opacity-30" />
    </div>
    <div class="flex-1">
      <p class:list={[textClass, 'leading-relaxed']}>{quote}</p>
    </div>
  </div>
  <div class="border-t pt-3">
    <p class="font-semibold text-base">{name}</p>
    <p class="text-sm text-foreground/60 font-mono">
      {role}
      {' · '}
      {
        companyUrl ? (
          <a href={companyUrl} target="_blank" rel="noopener noreferrer">
            {company}
          </a>
        ) : (
          company
        )
      }
    </p>
  </div>
</div>
