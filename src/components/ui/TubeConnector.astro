---
interface Props {
  /** SVG path data for the connector line */
  path: string;
  /** CSS transform rotate (degrees) */
  rotation?: number;
  /** animation-delay CSS value e.g. "-0.3s" */
  delay?: string;
  /** animation-direction */
  direction?: 'normal' | 'reverse';
  /** animation duration e.g. "0.9s" */
  duration?: string;
  /** stroke color for the base track */
  trackColor?: string;
  /** viewBox for the SVG */
  viewBox?: string;
  /** Whether to show dot terminals at start/end of path */
  showDots?: boolean;
  class?: string;
}

const {
  path,
  rotation,
  delay = '0s',
  direction = 'normal',
  duration = '0.8s',
  viewBox = '0 0 100 100',
  showDots = true,
  class: className = '',
} = Astro.props;

const style = [
  `--tube-delay:${delay}`,
  `--tube-direction:${direction}`,
  `--tube-duration:${duration}`,
  rotation !== undefined ? `transform:rotate(${rotation}deg)` : '',
]
  .filter(Boolean)
  .join(';');
---

<div class:list={['relative h-full w-full', className]} style={style}>
  <svg
    viewBox={viewBox}
    width="100%"
    height="100%"
    preserveAspectRatio="none"
    aria-hidden="true"
  >
    <!-- Base gray track -->
    <path
      d={path}
      fill="none"
      stroke="currentColor"
      stroke-width="1"
      class="opacity-20"
    ></path>
    <!-- Animated orange dashes -->
    <path
      d={path}
      fill="none"
      stroke="var(--color-orange-800)"
      stroke-width="1.5"
      class="tube-path"
    ></path>
    {
      showDots && (
        <>
          <circle cx="50" cy="0" r="3" fill="var(--color-orange-800)" opacity="0.5" />
          <circle cx="50" cy="100" r="3" fill="var(--color-orange-800)" opacity="0.5" />
        </>
      )
    }
  </svg>
</div>
